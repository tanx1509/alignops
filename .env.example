# PostgreSQL connection. For Supabase, use the pooled URL for runtime queries.
DATABASE_URL="postgresql://postgres:[password]@[host]:6543/postgres?pgbouncer=true&connection_limit=1"

# Optional direct connection for migrations. Recommended for Supabase.
DIRECT_URL="postgresql://postgres:[password]@[host]:5432/postgres"

# Supabase Auth / API.
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# App metadata.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Set to true only for local codegen/typecheck when secrets are not available.
SKIP_ENV_VALIDATION="false"
