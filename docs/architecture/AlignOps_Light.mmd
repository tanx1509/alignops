flowchart TB
  subgraph Portals["Role Portals"]
    direction LR
    E["<b>Employee</b><br/>Goal Cockpit"]
    M["<b>Manager</b><br/>Operating Center"]
    A["<b>Admin</b><br/>Governance Control Tower"]
  end

  subgraph Frontend["Next.js 14 App Router"]
    direction TB
    RSC["Server Components (RSC)"]
    Routes["Protected Route Groups<br/>/(employee) /(manager) /(admin)"]
    APIRoutes["Route Handlers<br/>/api/v1/*"]
    Middleware["Middleware Layer<br/>Session resolution · RBAC gate · Role redirect"]
  end

  subgraph Identity["Identity Boundary"]
    direction LR
    SupaAuth["Supabase Auth<br/>JWT · SSO-ready"]
    RoleClaims["Role Claims<br/>app_metadata · Entra-ready"]
    SessionResolver["Session Resolver<br/>user_id → AppRole mapping"]
  end

  subgraph Domain["Domain & Service Layer"]
    direction TB
    DAL["Data Access Layer (DAL)<br/>Prisma-backed service modules"]
    StateMachine["Goal Sheet State Machine<br/>DRAFT→SUBMITTED→APPROVED→LOCKED"]
    IntelEngine["Deterministic Execution Health Engine"]
    EscalationSvc["Escalation Service<br/>Rule evaluation · Event creation"]
    NotifSvc["Notification Dispatcher<br/>Teams card preview · Email simulation"]
    ReportSvc["Reporting & CSV Pipeline<br/>On-demand · Governance-grade"]
  end

  subgraph Intelligence["Execution Intelligence"]
    direction LR
    SMART["SMART Scorer"]
    KPIDupe["KPI Deduplication"]
    RiskEngine["Risk Engine"]
    WorkloadBalancer["Workload Balancer"]
    HealthScorer["Health Scorer"]
    ForecastEngine["Forecast Engine"]
  end

  subgraph Persistence["Persistence (Prisma ORM)"]
    direction TB
    PG["PostgreSQL / Supabase DB"]
    AuditLedger["Governance Audit Ledger<br/>Immutable event log"]
    EscLog["Escalation Events"]
    GoalSheets["Goal Sheets + KPIs<br/>Versioned · state-tracked"]
    OrgGraph["Org Unit Graph<br/>Hierarchical · role-scoped"]
  end

  E & M & A --> RSC
  RSC --> Routes
  Routes --> Middleware
  APIRoutes --> Middleware
  Middleware --> SupaAuth
  SupaAuth --> RoleClaims --> SessionResolver
  SessionResolver --> DAL
  Middleware --> DAL
  DAL --> StateMachine
  DAL --> IntelEngine
  DAL --> EscalationSvc
  DAL --> NotifSvc
  DAL --> ReportSvc
  IntelEngine --> SMART & KPIDupe & RiskEngine & WorkloadBalancer & HealthScorer & ForecastEngine
  DAL --> PG
  PG --> AuditLedger & EscLog & GoalSheets & OrgGraph

  classDef portals fill:#f8fafc,stroke:#94a3b8,stroke-width:2px,color:#0f172a,rx:12px,ry:12px
  classDef frontend fill:#eff6ff,stroke:#3b82f6,stroke-width:2px,color:#1e3a8a,rx:12px,ry:12px
  classDef identity fill:#f5f3ff,stroke:#8b5cf6,stroke-width:2px,color:#4c1d95,rx:12px,ry:12px
  classDef domain fill:#ecfeff,stroke:#06b6d4,stroke-width:2px,color:#164e63,rx:12px,ry:12px
  classDef intelligence fill:#ecfdf5,stroke:#10b981,stroke-width:2px,color:#064e3b,rx:12px,ry:12px
  classDef persistence fill:#fffbeb,stroke:#f59e0b,stroke-width:2px,color:#78350f,rx:12px,ry:12px

  class Portals portals
  class Frontend frontend
  class Identity identity
  class Domain domain
  class Intelligence intelligence
  class Persistence persistence
